    <P Name="Name">&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body align=&quot;left&quot; style=&quot; font-family:&apos;Helvetica&apos;; font-size:10px; font-weight:400; font-style:normal;&quot;&gt;
&lt;p align=&quot;left&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:24px;&quot;&gt;C(s)&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</P>
    <P Name="Position">[799, 728, 846, 758]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
    <P Name="Interpreter">rich</P>
  </Annotation>
  <Annotation SID="12">
    <P Name="Name">比例微分控制器，传递函数为15+2s</P>
    <P Name="Position">[665, 490, 980, 720]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
    <P Name="FixedHeight">on</P>
    <P Name="FixedWidth">on</P>
    <P Name="ForegroundColor">[0.901961, 0.901961, 1.000000]</P>
    <P Name="BackgroundColor">[0.901961, 0.901961, 1.000000]</P>
    <P Name="DropShadow">on</P>
    <P Name="AnnotationType">area_annotation</P>
    <P Name="ZOrder">25</P>
    <P Name="FontSize">12</P>
  </Annotation>
  <Annotation SID="10">
    <P Name="Name">&lt;!DOCTYPE HTML PUBLIC &apos;-//W3C//DTD HTML 4.0//EN&apos; &apos;http://www.w3.org/TR/REC-html40/strict.dtd&apos;&gt;
&lt;html&gt;
&lt;head&gt;
&lt;meta content=&quot;1&quot; name=&quot;qrichtext&quot;/&gt;
&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;
&lt;/head&gt;
&lt;body style=&quot; font-family:&apos;Helvetica&apos;; font-size:10px; font-weight:400; font-style:normal;&quot; align=&quot;left&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;4.3.4线性连续系统的仿真分析&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;例：4.5  &lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;完整的闭环传递函数：&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;math style=&quot;font-size:26px;&quot;&gt;$H(s) = \frac{C(s)G(s)}{1+C(s)G(s)} \cdot\frac{2s + 15}{s^2 + 2s +13.79}$&lt;/math&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;center&quot;&gt;
&lt;img height=&quot;197.25&quot; src=&quot;[$unpackedFolder]/simulink/resources/mwimg_cc4d84ca-4e5b-4431-a94a-10b1eb69799b.png&quot; width=&quot;282.75&quot;/&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;相当于是给了系统一个阶跃：&lt;/span&gt;
&lt;/p&gt;
&lt;/body&gt;
&lt;/html&gt;
</P>
    <P Name="Position">[415, 54, 866, 459]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
    <P Name="Interpreter">rich</P>
  </Annotation>
  <Annotation SID="16">
    <P Name="Name">&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body align=&quot;left&quot; style=&quot; font-family:&apos;Helvetica&apos;; font-size:10px; font-weight:400; font-style:normal;&quot;&gt;
&lt;p align=&quot;left&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:24px;&quot;&gt;G(s)&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</P>
    <P Name="Position">[1034, 593, 1082, 623]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
