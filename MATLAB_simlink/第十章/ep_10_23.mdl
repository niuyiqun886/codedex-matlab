  </Annotation>
  <Annotation SID="2">
    <P Name="Name">&lt;!DOCTYPE HTML PUBLIC &apos;-//W3C//DTD HTML 4.0//EN&apos; &apos;http://www.w3.org/TR/REC-html40/strict.dtd&apos;&gt;
&lt;html&gt;
&lt;head&gt;
&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot;/&gt;
&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;
&lt;/head&gt;
&lt;body style=&quot; font-family:&apos;Helvetica&apos;; font-size:10px; font-weight:400; font-style:normal;&quot; align=&quot;left&quot;&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;br/&gt;
&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;br/&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;例10-23已知一控制系统结构如下图：&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;img src=&quot;[$unpackedFolder]/simulink/resources/mwimg_f41eb701-128b-4b3a-8ba7-63b67d03a99c.png&quot;/&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;其中：&lt;/span&gt;
&lt;math style=&quot;font-size:26px;&quot;&gt;$G_{1}(s) = \frac{s + 1}{s^2 + 3s + 1};
G_{2}(s) = \frac{s + 2}{s^2 + 2s + 4};
G_{3}(s) = \frac{1}{s + 0.2}$&lt;/math&gt;
&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;br/&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;1.可以再matlab命令行窗口中输入几个模型：&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;G1 = tf([1 1],[1 3 1]);&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;G2 = tf([1 2],[1 2 4]);&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;G3 = tf(1,[1 0.2]);&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;G = (G1 + G2)*G3;&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;这个代码跑完只要在工作区中存储了，下面的就可以跑了&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;2.使用多个LTI system组成&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px;&quot;&gt;3.使用多个Transfer Fcn 组成&lt;/span&gt;
&lt;/p&gt;
&lt;/body&gt;
&lt;/html&gt;
</P>
    <P Name="Position">[152, -11, 957, 618]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
    <P Name="FixedHeight">on</P>
    <P Name="FixedWidth">on</P>
    <P Name="Interpreter">rich</P>
    <P Name="FontName">Helvetica</P>
    <P Name="FontSize">10</P>
    <P Name="FontWeight">normal</P>
    <P Name="FontAngle">normal</P>
  </Annotation>
</System>

