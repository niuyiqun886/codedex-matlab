  <Annotation SID="1">
    <P Name="Name">&lt;!DOCTYPE HTML PUBLIC &apos;-//W3C//DTD HTML 4.0//EN&apos; &apos;http://www.w3.org/TR/REC-html40/strict.dtd&apos;&gt;
&lt;html&gt;
&lt;head&gt;
&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot;/&gt;
&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;
&lt;/head&gt;
&lt;body style=&quot; font-family:&apos;Helvetica&apos;; font-size:10px; font-weight:400; font-style:normal;&quot; align=&quot;left&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-family:&apos;SimSun&apos;; font-size:26px;&quot;&gt;10.5控制系统仿真实例&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-family:&apos;SimSun&apos;; font-size:26px;&quot;&gt;例10-26&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;img src=&quot;[$unpackedFolder]/simulink/resources/mwimg_2eabcdd1-da64-41d2-bdb2-16431eb4d995.png&quot;/&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;math style=&quot;font-size:26px;&quot;&gt;$G_{1}(s) = \frac{s^2+3s+1}{2s^2+5s+3};G_{2}(s) = \frac{2(s+1)}{(s+2)(s+10)};G_{3}(s) = \frac{5}{s+7}$&lt;/math&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;math style=&quot;font-size:26px;&quot;&gt;$G_{4}(s) = \frac{s+0.3}{s^2+s+6};H(s) = 1.5$&lt;/math&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px; vertical-align:bottom;&quot;&gt;条件：G1，G3，G4为Transfer Fcn模块&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px; vertical-align:bottom;&quot;&gt;           G2为Zero-pole模块&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px; vertical-align:bottom;&quot;&gt;           H为增益模块&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot; align=&quot;left&quot;&gt;
&lt;span style=&quot; font-size:26px; vertical-align:bottom;&quot;&gt;           输入为Step阶跃信号&lt;/span&gt;
&lt;/p&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px; font-size:26px; vertical-align:bottom;&quot; align=&quot;left&quot;&gt;
&lt;br/&gt;
&lt;/p&gt;
&lt;/body&gt;
&lt;/html&gt;
</P>
    <P Name="Position">[210, 99, 1001, 747]</P>
    <P Name="InternalMargins">[0, 0, 0, 0]</P>
    <P Name="FixedHeight">on</P>
    <P Name="FixedWidth">on</P>
    <P Name="Interpreter">rich</P>
    <P Name="ZOrder">-1</P>
  </Annotation>
</System>

